{
  "name": "control-stock-empresa",
  "version": "1.9.6",
  "description": "Sistema de control de stock - entradas y salidas",
  "main": "main.js",
  "scripts": {
    "sync:legacy": "node scripts/sync-legacy-public.js",
    "dev:renderer": "npm run sync:legacy && vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env ELECTRON_RENDERER_URL=http://localhost:5173 electron .",
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "build:renderer": "npm run sync:legacy && vite build",
    "start": "electron .",
    "start:react": "npm run build:renderer && electron .",
    "dist": "npm run build:renderer && electron-builder",
    "dist:win": "npm run build:renderer && electron-builder --win --x64",
    "release": "npm run dist:win",
    "publish": "electron-builder --publish always"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/navarromateo09/BIENES-PATRIMONIALES-.git"
  },
  "keywords": [
    "stock",
    "inventario",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.bienesypatrimoniales.controlstock",
    "productName": "Bienes y Patrimoniales",
    "asar": true,
    "files": [
      "**/*",
      "!renderer/src/**",
      "!renderer/index.html",
      "!renderer/public/**",
      "!**/*.map",
      "!dist/**",
      "!scripts/**",
      "!*.md",
      "!import-dependencias-*.txt",
      "!supabase-*.sql",
      {
        "from": "node_modules/electron-updater",
        "to": "node_modules/electron-updater",
        "filter": ["**/*"]
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "icon": "build/icon.ico",
      "artifactName": "Bienes.y.Patrimoniales.Setup.${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "shortcutName": "BYP"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "navarromateo09",
        "repo": "BIENES-PATRIMONIALES-"
      }
    ]
  }
}
